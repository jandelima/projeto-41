{
  "name": "projeto-41",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "demo": "node scripts/demo.mjs",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "import": "npm run import -w @projeto41/api --",
    "icons": "npm run icons -w @projeto41/api",
    "windows:shortcut": "node scripts/install-windows-shortcut.mjs",
    "start": "npm run start -w @projeto41/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "eslint": "^9.28.0",
    "globals": "^17.6.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
