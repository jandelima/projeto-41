PORT=3001
DATABASE_URL=./data/projeto41.sqlite

# Token gratuito da brapi (https://brapi.dev) para cotacoes da B3.
BRAPI_TOKEN=

# Chave opcional do plano Demo do CoinGecko (https://www.coingecko.com/en/api).
